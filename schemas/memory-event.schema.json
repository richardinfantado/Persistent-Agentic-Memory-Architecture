{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pama/schemas/memory-event.schema.json",
  "title": "PAMSPEC Memory Event Candidate Schema",
  "description": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract.",
  "$defs": {
    "draftStatusWarning": {
      "const": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract."
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle": {
      "enum": [
        "scratch",
        "candidate",
        "active",
        "superseded",
        "deprecated",
        "archived",
        "redacted",
        "deleted"
      ]
    },
    "validation": {
      "enum": [
        "unverified",
        "corroborated",
        "disputed",
        "rejected"
      ]
    }
  },
  "type": "object",
  "required": [
    "draftStatusWarning",
    "event_id",
    "operation_id",
    "scope_id",
    "event_type",
    "occurred_at",
    "actor"
  ],
  "properties": {
    "draftStatusWarning": {
      "$ref": "#/$defs/draftStatusWarning"
    },
    "event_id": {
      "$ref": "#/$defs/id"
    },
    "operation_id": {
      "$ref": "#/$defs/id"
    },
    "scope_id": {
      "$ref": "#/$defs/id"
    },
    "object_id": {
      "type": "string"
    },
    "version_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "object_created",
        "object_updated",
        "lifecycle_transitioned",
        "validation_transitioned",
        "relationship_added",
        "relationship_removed",
        "provenance_attached",
        "embedding_generated",
        "index_rebuilt",
        "access_denied",
        "object_expired",
        "object_redacted",
        "object_deleted"
      ]
    },
    "occurred_at": {
      "$ref": "#/$defs/timestamp"
    },
    "actor": {
      "type": "object"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
