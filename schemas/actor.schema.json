{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pama/schemas/actor.schema.json",
  "title": "PAMSPEC Actor Candidate Schema",
  "description": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract.",
  "$defs": {
    "draftStatusWarning": {
      "const": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract."
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle": {
      "enum": [
        "scratch",
        "candidate",
        "active",
        "superseded",
        "deprecated",
        "archived",
        "redacted",
        "deleted"
      ]
    },
    "validation": {
      "enum": [
        "unverified",
        "corroborated",
        "disputed",
        "rejected"
      ]
    }
  },
  "type": "object",
  "required": [
    "draftStatusWarning",
    "actor_id",
    "actor_kind"
  ],
  "properties": {
    "draftStatusWarning": {
      "$ref": "#/$defs/draftStatusWarning"
    },
    "actor_id": {
      "$ref": "#/$defs/id"
    },
    "actor_kind": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
