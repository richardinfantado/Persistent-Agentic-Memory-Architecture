{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/richardinfantado/Persistent-Agentic-Memory-Architecture/main/schemas/0.1-draft/memory-event.schema.json",
  "title": "PAMSPEC Event Ledger Entry 0.1-draft",
  "$comment": "Pre-1.0 candidate interoperability schema.",
  "type": "object",
  "required": ["event_id", "operation_id", "scope_id", "event_type", "recorded_at", "sequence", "actor"],
  "properties": {
    "event_id": {"$ref": "common.schema.json#/$defs/id"},
    "operation_id": {"$ref": "common.schema.json#/$defs/id"},
    "scope_id": {"$ref": "common.schema.json#/$defs/id"},
    "object_id": {"type": "string"},
    "relationship_id": {"type": "string"},
    "version_id": {"type": "string"},
    "event_type": {
      "enum": [
        "object_created",
        "object_updated",
        "lifecycle_transitioned",
        "availability_transitioned",
        "retention_transitioned",
        "validation_transitioned",
        "relationship_created",
        "relationship_updated",
        "provenance_updated",
        "embedding_generated",
        "index_rebuilt",
        "access_denied",
        "object_redacted",
        "object_deleted",
        "working_memory_promoted",
        "tool_invoked",
        "tool_completed",
        "subscription_opened",
        "subscription_closed",
        "delegation_granted",
        "delegation_revoked",
        "delegation_exercised"
      ]
    },
    "recorded_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "sequence": {"type": "integer", "minimum": 1},
    "actor": {"$ref": "actor.schema.json"},
    "payload": {"type": "object"},
    "resource_usage": {
      "type": "object",
      "$comment": "Optional per-event accounting for cost and latency. Not authoritative; recorded for observability, budgeting, and evaluation. Absence carries no meaning.",
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "wall_clock_ms": {"type": "integer", "minimum": 0},
        "compute_ms": {"type": "integer", "minimum": 0},
        "cost_amount": {"type": "number", "minimum": 0},
        "cost_currency": {"type": "string", "minLength": 3, "maxLength": 3, "$comment": "ISO 4217 currency code (e.g., 'USD'), or an implementation-defined non-currency code such as 'CRD' for credits when documented."},
        "cost_unit": {"type": "string", "$comment": "Optional. If cost_amount is measured in a non-currency unit (e.g., 'credits'), describe it here."},
        "model_ref": {"type": "string"},
        "provider_ref": {"type": "string"},
        "region_ref": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "object_created",
              "object_updated",
              "lifecycle_transitioned",
              "availability_transitioned",
              "retention_transitioned",
              "validation_transitioned",
              "relationship_created",
              "relationship_updated",
              "provenance_updated",
              "object_redacted",
              "object_deleted"
            ]
          }
        }
      },
      "then": {"required": ["version_id"]}
    }
  ],
  "additionalProperties": false
}

