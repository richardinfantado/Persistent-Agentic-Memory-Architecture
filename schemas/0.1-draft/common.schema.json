{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/richardinfantado/Persistent-Agentic-Memory-Architecture/main/schemas/0.1-draft/common.schema.json",
  "title": "PAMSPEC Common Definitions 0.1-draft",
  "$comment": "Pre-1.0 candidate interoperability schema.",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.\\-]*:[A-Za-z0-9+._:\\-/]+$",
      "$comment": "Identifiers use a scheme-prefixed form (scheme:opaque) such as 'urn:uuid:...', 'mem:claim:001', or 'workspace:example'. A future revision may narrow this to RFC 8141 URNs or RFC 9562 UUIDs."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle_state": {
      "enum": ["scratch", "candidate", "active", "superseded", "deprecated", "archived"]
    },
    "availability_state": {
      "enum": ["available", "partially_redacted", "redacted", "deleted"]
    },
    "retention_state": {
      "enum": ["retained", "expired", "pending_deletion", "legal_hold"]
    },
    "validation_state": {
      "enum": ["unverified", "corroborated", "disputed", "rejected"]
    },
    "standard_object_type": {
      "$comment": "Relationship Objects are represented by relationship.schema.json and are intentionally excluded from this enumeration.",
      "enum": ["claim", "decision", "task", "artifact", "observation", "entity", "summary", "tool_invocation", "tool_result"]
    },
    "extension_object_type": {
      "type": "string",
      "anyOf": [
        {
          "pattern": "^[a-z0-9]+(?:\\.[a-z0-9-]+)+\\.[a-z][a-z0-9-]*$"
        },
        {
          "pattern": "^[a-z][a-z0-9+.-]*:"
        }
      ]
    },
    "integrity": {
      "type": "object",
      "properties": {
        "digest": {"type": "string", "minLength": 1},
        "algorithm": {"type": "string", "minLength": 1},
        "canonicalization_profile": {"type": "string", "minLength": 1},
        "signature": {"type": "string"},
        "ledger_ref": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
