{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/richardinfantado/Persistent-Agentic-Memory-Architecture/main/schemas/0.1-draft/common.schema.json",
  "title": "PAMSPEC Common Definitions 0.1-draft",
  "$comment": "Pre-1.0 candidate interoperability schema.",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.\\-]*:[A-Za-z0-9+._:\\-/]+$",
      "$comment": "Identifiers use a scheme-prefixed form (scheme:opaque) such as 'urn:uuid:...', 'mem:claim:001', or 'workspace:example'. A future revision may narrow this to RFC 8141 URNs or RFC 9562 UUIDs."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle_state": {
      "enum": ["scratch", "candidate", "active", "superseded", "deprecated", "archived"]
    },
    "availability_state": {
      "enum": ["available", "partially_redacted", "redacted", "deleted"]
    },
    "retention_state": {
      "enum": ["retained", "expired", "pending_deletion", "legal_hold"]
    },
    "validation_state": {
      "enum": ["unverified", "corroborated", "disputed", "rejected"]
    },
    "pamspec_operation": {
      "$comment": "Canonical set of PAMSPEC operation names. Single source of truth for delegation.schema.json, MCP binding tool descriptors, and any other artifact that enumerates operations. Adding an operation here is a coordinated change.",
      "enum": [
        "create",
        "read",
        "update",
        "transition",
        "relate",
        "query",
        "inspect_history",
        "redact",
        "delete",
        "promote",
        "subscribe",
        "unsubscribe"
      ]
    },
    "standard_object_type": {
      "$comment": "Relationship Objects are represented by relationship.schema.json and are intentionally excluded from this enumeration.",
      "enum": ["claim", "decision", "task", "artifact", "observation", "entity", "summary", "tool_invocation", "tool_result", "working_memory"]
    },
    "extension_object_type": {
      "type": "string",
      "anyOf": [
        {
          "pattern": "^[a-z0-9]+(?:\\.[a-z0-9-]+)+\\.[a-z][a-z0-9-]*$"
        },
        {
          "pattern": "^[a-z][a-z0-9+.-]*:"
        }
      ]
    },
    "integrity": {
      "type": "object",
      "properties": {
        "digest": {"type": "string", "minLength": 1},
        "algorithm": {"type": "string", "minLength": 1},
        "canonicalization_profile": {"type": "string", "minLength": 1},
        "signature": {"type": "string"},
        "ledger_ref": {"type": "string"}
      },
      "additionalProperties": false
    },
    "quality_signals": {
      "type": "object",
      "$comment": "Optional machine-readable quality signals produced by automated processes. Non-authoritative; retrieval ranking and default filters MAY use them but authoritative validation remains governed by validation_state.",
      "properties": {
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "contradiction_score": {"type": "number", "minimum": 0, "maximum": 1, "$comment": "0 = no known contradictions, 1 = strongly contradicted by other memory."},
        "staleness_score": {"type": "number", "minimum": 0, "maximum": 1, "$comment": "0 = fresh, 1 = highly stale relative to related memory."},
        "evidence_strength": {"type": "number", "minimum": 0, "maximum": 1},
        "source_diversity": {"type": "number", "minimum": 0, "maximum": 1},
        "last_verified_at": {"$ref": "#/$defs/timestamp"},
        "last_verified_by_actor_id": {"$ref": "#/$defs/id"},
        "verification_method_id": {"type": "string"},
        "assessed_at": {"$ref": "#/$defs/timestamp"},
        "assessed_by_actor_id": {"$ref": "#/$defs/id"}
      },
      "additionalProperties": false
    }
  }
}
