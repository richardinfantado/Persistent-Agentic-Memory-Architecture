{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/richardinfantado/Persistent-Agentic-Memory-Architecture/main/schemas/0.1-draft/relationship.schema.json",
  "title": "PAMSPEC Relationship Object 0.1-draft",
  "$comment": "Pre-1.0 candidate interoperability schema.",
  "type": "object",
  "required": [
    "spec_version",
    "relationship_id",
    "version_id",
    "scope_id",
    "relationship_type",
    "source_object_id",
    "target_object_id",
    "directionality",
    "canonical_content",
    "lifecycle_state",
    "availability_state",
    "retention_state",
    "validation_state",
    "committed_at",
    "recorded_at",
    "sequence",
    "provenance"
  ],
  "properties": {
    "spec_version": {"const": "0.1.0-draft"},
    "relationship_id": {"$ref": "common.schema.json#/$defs/id"},
    "version_id": {"$ref": "common.schema.json#/$defs/id"},
    "scope_id": {"$ref": "common.schema.json#/$defs/id"},
    "relationship_type": {"type": "string", "minLength": 1},
    "source_object_id": {"$ref": "common.schema.json#/$defs/id"},
    "target_object_id": {"$ref": "common.schema.json#/$defs/id"},
    "target_scope_id": {"type": "string"},
    "directionality": {"enum": ["directed", "bidirectional", "undirected"]},
    "canonical_content": {},
    "lifecycle_state": {"$ref": "common.schema.json#/$defs/lifecycle_state"},
    "availability_state": {"$ref": "common.schema.json#/$defs/availability_state"},
    "retention_state": {"$ref": "common.schema.json#/$defs/retention_state"},
    "validation_state": {"$ref": "common.schema.json#/$defs/validation_state"},
    "committed_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "recorded_at": {"$ref": "common.schema.json#/$defs/timestamp"},
    "sequence": {"type": "integer", "minimum": 1},
    "provenance": {"$ref": "provenance.schema.json"},
    "policy_basis": {"type": "string"},
    "integrity": {"type": "object"}
  },
  "additionalProperties": false
}
