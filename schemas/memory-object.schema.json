{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pama/schemas/memory-object.schema.json",
  "title": "PAMSPEC Memory Object Candidate Schema",
  "description": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract.",
  "$defs": {
    "draftStatusWarning": {
      "const": "Unstable pre-0.1 review schema for draft-infantado-agent-memory-architecture-00; candidate interoperability model, not a frozen protocol contract."
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle": {
      "enum": [
        "scratch",
        "candidate",
        "active",
        "superseded",
        "deprecated",
        "archived",
        "redacted",
        "deleted"
      ]
    },
    "validation": {
      "enum": [
        "unverified",
        "corroborated",
        "disputed",
        "rejected"
      ]
    }
  },
  "type": "object",
  "required": [
    "draftStatusWarning",
    "spec_version",
    "object_id",
    "version_id",
    "scope_id",
    "object_type",
    "canonical_content",
    "lifecycle_state",
    "validation_state",
    "created_at",
    "updated_at",
    "actor",
    "provenance"
  ],
  "properties": {
    "draftStatusWarning": {
      "$ref": "#/$defs/draftStatusWarning"
    },
    "spec_version": {
      "type": "string"
    },
    "object_id": {
      "$ref": "#/$defs/id"
    },
    "version_id": {
      "$ref": "#/$defs/id"
    },
    "scope_id": {
      "$ref": "#/$defs/id"
    },
    "object_type": {
      "enum": [
        "claim",
        "decision",
        "task",
        "artifact",
        "observation",
        "entity",
        "relation",
        "summary"
      ]
    },
    "schema_id": {
      "type": "string"
    },
    "canonical_content": {
      "type": "object"
    },
    "lifecycle_state": {
      "$ref": "#/$defs/lifecycle"
    },
    "validation_state": {
      "$ref": "#/$defs/validation"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "actor_kind"
      ]
    },
    "provenance": {
      "type": "object"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "integrity": {
      "type": "object"
    },
    "derived": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
